# ─── teg-ingestion environment ──────────────────────────────────────────────
# Copy to `.env` and fill in. Settings use the TEG_ prefix (pydantic-settings);
# the Stage 0 Neo4j script uses NEO4J_* (no prefix).

# ── Stage 1 generate_docs_local.py needs Jira + the LLM gateway ──────────────

# Jira (fetch the Engagement Request + linked Themes)
TEG_JIRA_BASE_URL=https://jira.your-org.net
TEG_JIRA_TOKEN=                       # Personal Access Token (Bearer)
# TEG_JIRA_VALUE_STREAM_FIELD=         # Business Value Stream customfield id; discovered by name if blank
# TEG_JIRA_VERIFY_SSL=false

# LLM gateway (condense)
TEG_LLM_BASE_URL=https://idp-core-platform-api.your-org.net
TEG_LLM_MODEL=gpt-5-mini-idp
TEG_LLM_APP_ID=
# TEG_LLM_COMPLETION_PATH=/api/v1/chatcompletions
# TEG_LLM_API_VERSION=2024-04-01-preview

# IDP auth (used by the LLM + embeddings gateway clients)
TEG_IDP_AUTH_URL=
TEG_IDP_CLIENT_ID=
TEG_IDP_CLIENT_SECRET=
TEG_IDP_USER=
TEG_IDP_PASSWORD=

# Embeddings — only needed if you run generate_docs_local.py --embed
TEG_EMBEDDING_MODEL=text-embedding-3-small-idp
# TEG_EMBEDDING_PATH=/api/v1/embeddings

# ── Stage 0 fetch_idmt_vs_valid_tickets.py — Neo4j (no TEG_ prefix) ──────────
NEO4J_URI=bolt://your-neo4j-host:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

# ── Persistence: cosmos_ingest.py + upload_index.py (run `uv sync --extra azure`) ─────
# Not needed for generate_docs_local.py (local only). Each setting reads its TEG_ name OR the
# org's AZURE_* name (whichever is set) - fill one.

# Cosmos (system of record). Auth: the azure service principal below if set, else TEG_COSMOS_KEY.
TEG_COSMOS_ENDPOINT=                    # or org: AZURE_COSMOS_DB_URL
# TEG_COSMOS_KEY=                       # account key (only if not using the service principal)
TEG_COSMOS_DATABASE=                    # or org: AZURE_COSMOS_DB_NAME
TEG_COSMOS_CONTAINER=theme-and-epic    # or org: AZURE_COSMOS_CONTAINER_NAME

# AI Search index (retrieval). Auth: the azure service principal below if set, else the api key.
TEG_SEARCH_ENDPOINT=
# TEG_SEARCH_API_KEY=                   # admin key (only if not using the service principal)
TEG_SEARCH_INDEX=idp_teg_data
# TEG_SEARCH_API_VERSION=2024-07-01     # needs >=2024-07-01 for the vector + complex schema

# Azure service principal (preferred over keys). Reads TEG_* or the org's AZURE_*_DEV name.
# The principal must have the "Cosmos DB Built-in Data Contributor" data role on the account.
TEG_AZURE_TENANT_ID=                    # or org: AZURE_TENANT_ID_DEV
TEG_AZURE_CLIENT_ID=                    # or org: AZURE_CLIENT_ID_DEV
TEG_AZURE_CLIENT_SECRET=               # or org: AZURE_CLIENT_SECRET_DEV
